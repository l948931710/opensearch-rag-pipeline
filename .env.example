RAG_SIMULATE=false
RAG_ENVIRONMENT=development
RAG_LOG_LEVEL=INFO

# Gemini API 配置
RAG_GEMINI_API_KEY=your_gemini_api_key_here
RAG_EMBEDDING_DIMENSION=1024

# OSS 配置 (不再被 OCR 强制依赖)
RAG_OSS_ENDPOINT=oss-cn-chengdu.aliyuncs.com
RAG_OSS_ACCESS_KEY_ID=your_oss_ak_here
RAG_OSS_ACCESS_KEY_SECRET=your_oss_sk_here
RAG_OSS_BUCKET_NAME=your_bucket_name

# RDS MySQL 配置
RAG_RDS_HOST=localhost
RAG_RDS_PORT=3306
RAG_RDS_USER=root
RAG_RDS_PASSWORD=your_password
RAG_RDS_DATABASE=fuling_knowledge

# OpenSearch 配置
RAG_OPENSEARCH_HOST=localhost
RAG_OPENSEARCH_PORT=9200
RAG_OPENSEARCH_USER=admin
RAG_OPENSEARCH_PASSWORD=admin_password
RAG_OPENSEARCH_INDEX=fuling_knowledge_v1
RAG_OPENSEARCH_USE_SSL=false
RAG_OPENSEARCH_VERIFY_CERTS=false

# DashScope / 阿里云百炼 API 配置
RAG_DASHSCOPE_API_KEY=your_dashscope_api_key_here
RAG_LLM_MODEL=qwen3.6-plus
RAG_EMBEDDING_MODEL=text-embedding-v4

# OpenSearch 向量检索版 (HA3 Engine) 配置
RAG_HA3_ENDPOINT=ha-cn-xxx.ha.aliyuncs.com
RAG_HA3_INSTANCE_ID=ha-cn-xxx
RAG_HA3_USER=your_ha3_user
RAG_HA3_PASSWORD=your_ha3_password
RAG_HA3_TABLE_NAME=fuling_kb_chunks

# RAG 问答 API 配置（旧版示例误写成 RAG_RAG_* 双前缀，那些名字从未生效）
RAG_TOP_K=7
RAG_MAX_CONTEXT_CHARS=6000
RAG_API_PORT=8000
RAG_MAX_HISTORY_TURNS=10

# 钉钉互动卡片配置
DINGTALK_CLIENT_ID=your_app_key
DINGTALK_CLIENT_SECRET=your_app_secret
DINGTALK_CARD_TEMPLATE_ID=your_card_template_id
DINGTALK_CARD_CALLBACK_ROUTE_KEY=rag_feedback_callback

# 钉钉 Stream 模式（出站 WSS 收机器人消息/卡片回调，免公网回调端点）。
# ⚠️ 只在生产 SAE 上开启；本地对生产应用开启会"分担"走生产用户的消息
# （Stream 是连接分担模型，同 clientId 的所有在线连接共同消费推送）。
# DINGTALK_STREAM_MODE=true

# ══ 环境分工与守卫（docs/environment_design.md）══════════════════════
# 六层环境：SIM(空) / local / local_ab_* / staging / prod_ro(test 为弃用别名) / 生产(平台注入，不设 RAG_ENV)
# RAG_ENVIRONMENT 是安全等级（development/staging/production），与 RAG_ENV 正交。

# PROD-RO 只读会话声明（.env.prod_ro 内置；写路径一律被 env_guard 拦截）
# RAG_READONLY=true

# 守卫豁免（确知风险时显式声明，值必须精确匹配）：
# RAG_ALLOW_REMOTE_DB=read_only_ack        # 非生产标签连远程/生产 RDS
# RAG_ALLOW_REMOTE_SEARCH=read_only_ack    # 非生产标签连生产 HA3/OpenSearch
# RAG_DESTRUCTIVE_PROD_ACK=<op>:<YYYY-MM-DD>  # 非生产环境对生产目标的破坏性写，当日有效
# RAG_ALLOW_SHELL_OVERRIDE=VAR1,VAR2       # overlay file-wins 的单变量逃生口

# STAGING 专属（.env.staging；加载期强校验 _stg/-staging 后缀）
# RAG_RDS_OPERATION_DATABASE=fuling_operation_stg

# ══ Stage-3 推送后 HA3 物理存在性校验 + 有界补推（DAG-3 节点 04b）═════════
# HA3 偶发静默丢档（push failed=0 + RDS INDEXED，但 HA3 实际不存在）。开启后，停用旧版本前
# 重新读 HA3 确认本批 chunk 真实存在，对确认丢失的有界补推；补救失败/无法确认则中断防止丢失。
# 默认关闭——先 controlled validation（观察 healed 与 ~1% 丢档相符、settle 后无误补推）再 default-on。
# RAG_STAGE3_PARITY_VERIFY=true
# RAG_STAGE3_PARITY_SETTLE_SEC=30          # 校验前/补推后 settle，吸收实时索引最终一致性滞后（人工运维曾见 ~120s，point-read 收敛更快）
# RAG_STAGE3_PARITY_MAX_RETRIES=2          # 确认丢失的有界补推次数上限
# RAG_STAGE3_PARITY_POINTREAD_ALL_MAX=200  # 批 chunk 数 ≤ 此值则全量 point-read（跳过不确定的 id-range 枚举）

# ══ 首次入库 chunk-爆炸防线（DAG-2 node_chunk_documents）═══════════════════
# 单元格化 xlsx 等可产出上万 table_chunk 垃圾块。开启后超阈值的文档按 mode 处理：
# warn=仅告警仍入库；quarantine=丢弃本轮 chunks + 标记隔离（旧版本继续服务）。默认关闭。
# RAG_CHUNK_EXPLOSION_GATE=true
# RAG_CHUNK_EXPLOSION_MODE=warn            # warn | quarantine（默认 warn）
# RAG_CHUNK_EXPLOSION_MAX=2000             # 单文档 chunk 数上限（>此值触发）
# RAG_CHUNK_EXPLOSION_DEGENERATE_MIN=200   # 退化型判定的最小 chunk 数
# RAG_CHUNK_EXPLOSION_DOMINANT_FRAC=0.95   # 单一 table_chunk 类型占比阈值（退化型）

# ══ 图像 OCR 文本 PII 检测（DAG-2 node_detect_sensitive / node_redact_or_quarantine）══
# base text 扫不到截图/嵌图里的电话/身份证/密钥（CE38C5 等）。开启后对 asset['ocr_text']（不含
# visual_summary）跑实体+关键词检测：high→整文档隔离，medium→就地脱敏 ocr_text。默认关闭。
# ⚠️ 启用前须用真实 CE38C5 OCR 样本验证物料编码 FP allow-list；脱敏仅本轮内存生效，不回写
# canonical OSS，受影响文档后续重切仍需本 flag 持续开启。
# RAG_IMAGE_OCR_PII=true

# ══ 跨文档内容去重（DAG-1 node_build_canonical）═══════════════════════════
# exact-hash 捕获 intra-doc gate 漏掉的 dup-of-public / 跨部门精确副本。默认 WARN-and-process；
# 仅当存在"可见性完整覆盖新文档受众"的 active incumbent 时才 SKIP（避免 ACL 静默降级）。默认关闭。
# ⚠️ 启用前提：先应用 schema/005_cross_doc_dedup_index.sql（idx_canonical_sha256，否则 Stage-1
# 热路径全表扫），并按需回填 canonical_sha256 提升命中率（均为 gated prod write）。
# RAG_DEDUP_CROSS_DOC=true
