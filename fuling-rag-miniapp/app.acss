/* ============================================================
   富岭知识助手 — Aurora-Forest 设计令牌系统（v1.1 原型 1:1 移植）
   浅色放 page{}；深色放 @media (prefers-color-scheme: dark)。
   令牌只放颜色/渐变/阴影/纹理 —— 尺寸一律写字面 rpx：
   rpx 写进 custom property 编译器不换算，是已知坑。
   预计算 rgba 替代 color-mix（旧版钉钉 WebView 整条声明会被丢弃）。
   ============================================================ */
@import "./styles/icons.acss";

@font-face {
  font-family: "flico";
  src: url("data:font/woff2;charset=utf-8;base64,") format("woff2");
  font-weight: normal;
  font-style: normal;
}

page {
  /* brand — Aurora Forest（深林绿 + 极光绿）；--brand 用于文字/图标，
     --brand-strong 用于需要白字的填充（渐变上白字仅 1.9:1，不可用） */
  --brand: #15604a;
  --brand-strong: #134f3e;
  --brand-press: #0e3f31;
  --brand-soft: #d9ebe2;
  --brand-a16: rgba(21, 96, 74, 0.16);
  --brand-a30: rgba(21, 96, 74, 0.30);
  --brand-a40: rgba(21, 96, 74, 0.40);
  --brand-grad: linear-gradient(135deg, #0f5a43 0%, #1f9d76 60%, #34d6a3 100%);
  --nav-grad: linear-gradient(125deg, #103f30 0%, #17795b 55%, #2bbf95 100%);
  /* cotton-paper 棉纸底色 */
  --page: #efe8da;
  --page-tint: #dcebe2;
  --chat-bg: #ece4d4;
  --surface: #fbf8f1;
  --surface-2: #f4efe3;
  --surface-3: #ece5d6;
  /* warm ink */
  --text-1: #2a2620;
  --text-2: #5b5347;
  --text-3: #6f6657;
  --line: #e3dccb;
  --line-2: #efe9db;
  --divider-bg: rgba(91, 83, 71, 0.12);
  --success: #116449;
  --success-bg: #d9ece4;
  --warn: #82590c;
  --warn-bg: #f3e7cf;
  --danger: #b3402f;
  --danger-soft: #c2503c;
  --danger-bg: #f6e2dc;
  --me-grad: linear-gradient(135deg, #8a7f6c, #6b6253);
  --sh-1: 0 1px 2px rgba(60, 50, 30, 0.06);
  --sh-2: 0 1px 3px rgba(60, 50, 30, 0.07), 0 6px 16px rgba(60, 50, 30, 0.08);
  --sh-3: 0 10px 34px rgba(40, 35, 20, 0.16);
  --sh-brand: 0 4px 14px rgba(21, 96, 74, 0.26);
  /* 棉纸 feTurbulence 纹理（待真机 Android 钉钉冒烟；不行换预栅格化 PNG，
     分层声明保持 var(--paper), radial-gradient(...), var(--page) 不变，纯色优雅退化） */
  --paper: url("data:image/svg+xml,%3Csvg%20xmlns%3D%27http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%27%20width%3D%27220%27%20height%3D%27220%27%3E%3Cfilter%20id%3D%27pp%27%3E%3CfeTurbulence%20type%3D%27fractalNoise%27%20baseFrequency%3D%270.9%27%20numOctaves%3D%272%27%20stitchTiles%3D%27stitch%27%2F%3E%3CfeColorMatrix%20type%3D%27saturate%27%20values%3D%270%27%2F%3E%3CfeComponentTransfer%3E%3CfeFuncA%20type%3D%27linear%27%20slope%3D%270.05%27%2F%3E%3C%2FfeComponentTransfer%3E%3C%2Ffilter%3E%3Crect%20width%3D%27100%25%27%20height%3D%27100%25%27%20filter%3D%27url%28%23pp%29%27%2F%3E%3C%2Fsvg%3E");
  --user-bubble: var(--brand-strong);
  --scrim: rgba(15, 20, 15, 0.92);
  --toast-bg: rgba(30, 36, 28, 0.94);

  background: var(--paper), radial-gradient(900px 500px at 50% -8%, var(--page-tint) 0%, transparent 60%), var(--page);
  color: var(--text-1);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB',
    'Microsoft YaHei', sans-serif;
  font-size: 29rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

@media (prefers-color-scheme: dark) {
  page {
    --brand: #34e0ad;
    --brand-strong: #15795a;
    --brand-press: #0f5f47;
    --brand-soft: #103127;
    --brand-a16: rgba(52, 224, 173, 0.16);
    --brand-a30: rgba(52, 224, 173, 0.30);
    --brand-a40: rgba(52, 224, 173, 0.40);
    --brand-grad: linear-gradient(135deg, #0f6a4e 0%, #22c08e 100%);
    --nav-grad: linear-gradient(125deg, #0a2a20 0%, #115740 55%, #1f9d76 100%);
    --page: #0c1611;
    --page-tint: #10261c;
    --chat-bg: #0e1a14;
    --surface: #16271e;
    --surface-2: #121f18;
    --surface-3: #1d2f25;
    --text-1: #e9efe9;
    --text-2: #a7b6ac;
    --text-3: #8a988d;
    --line: #26352b;
    --line-2: #1b271f;
    --divider-bg: rgba(167, 182, 172, 0.14);
    --success: #3dd9a0;
    --success-bg: #0e2a1f;
    --warn: #e0a93a;
    --warn-bg: #2c2310;
    --danger: #ff7a66;
    --danger-soft: #ff7a66;
    --danger-bg: #2a1714;
    --me-grad: linear-gradient(135deg, #7c8a7e, #586256);
    --sh-1: 0 1px 2px rgba(0, 0, 0, 0.4);
    --sh-2: 0 1px 3px rgba(0, 0, 0, 0.45), 0 8px 20px rgba(0, 0, 0, 0.5);
    --sh-3: 0 12px 40px rgba(0, 0, 0, 0.6);
    --sh-brand: 0 4px 16px rgba(34, 192, 142, 0.25);
    --paper: url("data:image/svg+xml,%3Csvg%20xmlns%3D%27http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%27%20width%3D%27220%27%20height%3D%27220%27%3E%3Cfilter%20id%3D%27pp%27%3E%3CfeTurbulence%20type%3D%27fractalNoise%27%20baseFrequency%3D%270.9%27%20numOctaves%3D%272%27%20stitchTiles%3D%27stitch%27%2F%3E%3CfeColorMatrix%20type%3D%27saturate%27%20values%3D%270%27%2F%3E%3CfeComponentTransfer%3E%3CfeFuncA%20type%3D%27linear%27%20slope%3D%270.07%27%2F%3E%3C%2FfeComponentTransfer%3E%3C%2Ffilter%3E%3Crect%20width%3D%27100%25%27%20height%3D%27100%25%27%20filter%3D%27url%28%23pp%29%27%2F%3E%3C%2Fsvg%3E");
    --toast-bg: rgba(6, 12, 9, 0.95);
  }
}

view,
text,
input,
textarea,
scroll-view,
image {
  box-sizing: border-box;
}
