.wv-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 180rpx;
}

.wv-ico {
  font-size: 64rpx;
  color: var(--text-3);
  margin-bottom: 20rpx;
}

.wv-title {
  font-size: 28rpx;
  color: var(--text-3);
}

.wv-tip {
  font-size: 24rpx;
  color: var(--text-3);
  margin-top: 16rpx;
  padding: 0 60rpx;
  text-align: center;
  line-height: 1.6;
}
