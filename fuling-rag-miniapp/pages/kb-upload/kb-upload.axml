<web-view a:if="{{src}}" src="{{src}}" binderror="onWvError"></web-view>
<view a:elif="{{err}}" class="wv-state">
  <text class="wv-ico ico ico-warn"></text>
  <text class="wv-title">{{err}}</text>
  <text class="wv-tip">电脑端：浏览器打开知识库管理，同样可上传 / 升版 / 退役。</text>
</view>
<view a:else class="wv-state">
  <text class="wv-title">加载中…</text>
</view>
